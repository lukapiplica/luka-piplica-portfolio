---
/**
 * Root contact page - fallback for non-locale paths
 */
import { getLocaleFromPath } from '@/i18n';
import ContactContent from '@/components/patterns/ContactContent.astro';

const locale = getLocaleFromPath(Astro.url.pathname);
---

<ContactContent locale={locale} />

<style>
  /* Dummy style to force Astro to collect assets for this page */
  .force-asset-collection { display: block; }
</style>
