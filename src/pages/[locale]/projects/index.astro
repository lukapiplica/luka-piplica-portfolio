---
import ProjectsContent from '@/components/patterns/ProjectsContent.astro';
import { getLocales } from '@/i18n';

export function getStaticPaths() {
  return getLocales().map((locale) => ({ params: { locale } }));
}

interface Props {
  locale?: string;
}

const { locale = Astro.params.locale } = Astro.props;
---

<ProjectsContent locale={locale as string} />

<style>
  /* Dummy style to force Astro to collect assets for this page */
  .force-asset-collection { display: block; }
</style>
