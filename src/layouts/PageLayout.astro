---
/**
 * PageLayout
 * Layout wrapper for standard content pages (non-landing)
 * Uses Header + Footer with content page configuration
 */
import type { Thing, WithContext } from 'schema-dts';
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  nofollow?: boolean;
  showScrollProgress?: boolean;
  eagerReveal?: boolean;
  locale?: string;
  extraSchemas?: WithContext<Thing>[];
}

const { title, description, image, imageAlt, noindex, nofollow, showScrollProgress = false, eagerReveal = false, locale, extraSchemas = [] } = Astro.props;

---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  noindex={noindex}
  nofollow={nofollow}
  eagerReveal={eagerReveal}
  locale={locale}
  extraSchemas={extraSchemas}
>
  <Header
    slot="header"
    position="fixed"
    shape="bar"
    variant="solid"
    size="lg"
    showActiveState
    showCta={false}
    showScrollProgress={showScrollProgress}
    locale={locale}
  />

  <main class="min-h-screen pt-16">
    <slot />
  </main>

  <Footer slot="footer" layout="simple" locale={locale} />
</BaseLayout>
