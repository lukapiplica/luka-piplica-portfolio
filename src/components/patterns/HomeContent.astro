---
/**
 * Shared Home Index Content
 * Handles rendering the homepage content with full internationalization (i18n)
 * and correct dynamic collection queries filtered by locale.
 */
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import { getCollection } from 'astro:content';
import { t, localizedPath } from '@/i18n';

interface Props {
  locale: string;
}

const { locale } = Astro.props;

// Fetch and filter projects by current locale and active state
const projectItems = await getCollection('projects', ({ data }) => !data.draft && data.locale === locale);
const featuredProjects = projectItems
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

// Fetch and filter blog posts by current locale
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.locale === locale);
const posts = allPosts
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);

const getPostUrl = (postId: string) => {
  // Strip locale segment from the post ID to resolve the path correctly (e.g. "en/welcome" -> "welcome")
  const slug = postId.replace(new RegExp(`^${locale}/`), '').replace(/\.mdx?$/, '');
  return localizedPath(`/blog/${slug}`, locale);
};

const getProjectUrl = (projectId: string) => {
  // Strip locale prefix from ID (e.g. "en/welcome" -> "welcome")
  const slug = projectId.replace(new RegExp(`^${locale}/`), '').replace(/\.mdx?$/, '');
  return localizedPath(`/projects/${slug}`, locale);
};
---

<LandingLayout
  title={`${t('home.hero.titlePart1', locale)} ${t('home.hero.titlePart2', locale)}`}
  description={t('home.hero.description', locale)}
  image="/og-default.svg"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
  locale={locale}
>
  <!-- Hero -->
  <Hero layout="centered" size="xl" class="hero-dark-gradient" showScrollIndicator>
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-200">
      {t('home.hero.badge', locale)}
    </Badge>

    <h1 slot="title">
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor]">{t('home.hero.titlePart1', locale)}</span><br />
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor]">{t('home.hero.titlePart2', locale)}</span>
    </h1>

    <p slot="description">
      {t('home.hero.description', locale)}
    </p>

    <Fragment slot="actions">
      <Button size="lg" href={localizedPath('/blog/luka-piplica-cv', locale)}>
        {t('home.hero.viewCv', locale)}
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href={localizedPath('/contact', locale)}>
        <Icon name="mail" size="sm" />
        {t('home.hero.contactMe', locale)}
